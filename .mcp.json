{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "solas-run": {
            "command": "php",
            "args": [
                "artisan",
                "mcp:start",
                "solas-run"
            ]
        },
        "herd": {
            "command": "php",
            "args": [
                "/Applications/Herd.app/Contents/Resources/herd-mcp.phar"
            ],
            "env": {
                "SITE_PATH": "/Users/briancash/Herd/goals26"
            }
        }
    }
}