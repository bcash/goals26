{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "solas-run": {
            "command": "php",
            "args": [
                "artisan",
                "mcp:start",
                "solas-run"
            ]
        }
    }
}